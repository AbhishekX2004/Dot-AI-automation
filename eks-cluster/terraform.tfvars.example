# Copy this file to terraform.tfvars and fill in the values.
# Only override what you want to change — everything else falls back to the
# defaults defined in variables.tf.

# ── AWS Region ────────────────────────────────────────────────────────────────
aws_region  = "us-east-1"
environment = "dev"

# ── Cluster ───────────────────────────────────────────────────────────────────
cluster_name    = "dot-ai-eks"
cluster_version = "1.32"   # Run: aws eks describe-addon-versions to get latest

# ── Networking ────────────────────────────────────────────────────────────────
# Number of AZs to use (1–3). Lower = cheaper (fewer cross-AZ charges).
azs_count = 2

# ── Node Group ────────────────────────────────────────────────────────────────
node_instance_type  = "t3.small"
node_capacity_type  = "ON_DEMAND"   # Change to "SPOT" for ~70% cheaper spot instances
node_desired_size   = 2
node_min_size       = 1
node_max_size       = 4
node_disk_size_gb   = 20

# ── Add-ons ───────────────────────────────────────────────────────────────────
enable_coredns        = true
enable_kube_proxy     = true
enable_vpc_cni        = true
enable_ebs_csi_driver = true

# ── Extra tags (optional) ─────────────────────────────────────────────────────
tags = {
  Owner = "dot-ai-team"
}
