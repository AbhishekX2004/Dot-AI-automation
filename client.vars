#!/usr/bin/env bash
# =============================================================================
# client.vars — Dot-AI Client Onboarding Configuration
# =============================================================================
# Copy this file to a client-specific name, e.g.:
#   cp client.vars acme-corp.vars
# Fill in the required fields, then run:
#   ./onboard-client.sh acme-corp.vars
#
# Lines starting with # are comments. Do NOT quote values unless they
# contain spaces. The script sources this file directly.
# =============================================================================


# -----------------------------------------------------------------------------
# [REQUIRED] CLIENT IDENTITY
# -----------------------------------------------------------------------------
# A unique slug for this client. Used as:
#   - the Hub namespace name     (e.g. "acme-corp")
#   - the Helm release name      (e.g. "dot-ai-acme-corp")
#   - the kubeconfig secret name (e.g. "client-acme-corp-kubeconfig")
#   - subdomain prefix for ingress (e.g. "acme-corp.hub.example.com")
# Rules: lowercase, hyphens only, no dots or underscores.
CLIENT_ID=acme-corp


# -----------------------------------------------------------------------------
# [REQUIRED] HUB CLUSTER
# -----------------------------------------------------------------------------
# The kubectl context that points to your Hub EKS cluster.
# Run `kubectl config get-contexts` to see available contexts.
HUB_CONTEXT=arn:aws:eks:us-east-1:123456789012:cluster/dot-ai-eks


# -----------------------------------------------------------------------------
# [REQUIRED] CLIENT CLUSTER — CLOUD PROVIDER
# -----------------------------------------------------------------------------
# Which cloud the client cluster lives on.
# Supported values: eks | gke | acp | file
CLOUD_PROVIDER=eks


# --- EKS (set if CLOUD_PROVIDER=eks) ----------------------------------------
AWS_REGION=us-east-1
EKS_CLUSTER_NAME=client-prod-cluster
# Optional: AWS profile to use. Leave blank to use the default/env-var profile.
AWS_PROFILE=


# --- GKE (set if CLOUD_PROVIDER=gke) ----------------------------------------
GKE_PROJECT=my-gcp-project
GKE_CLUSTER_NAME=client-prod-cluster
# Use a regional cluster? Set GKE_ZONE to the region (e.g. us-central1)
# Use a zonal cluster?  Set GKE_ZONE to the zone   (e.g. us-central1-a)
GKE_ZONE=us-central1-a


# --- ACP / Generic (set if CLOUD_PROVIDER=acp) -------------------------------
# Any cluster that exposes a plain HTTPS Kubernetes API with a bearer token.
ACP_SERVER_URL=https://acp.example.com
ACP_TOKEN=your-bearer-token-here
# Set to "true" to skip TLS verification (not recommended for production).
ACP_INSECURE=false


# --- File (set if CLOUD_PROVIDER=file) ----------------------------------------
# Absolute or relative path to an existing kubeconfig file.
KUBECONFIG_FILE=./client.kubeconfig
# The context name inside the kubeconfig to use. Leave blank for current-context.
KUBECONFIG_FILE_CONTEXT=


# -----------------------------------------------------------------------------
# [REQUIRED] INGRESS
# -----------------------------------------------------------------------------
# The base domain used to build ingress hostnames.
# The script will create:
#   dot-ai API : dot-ai-<CLIENT_ID>.<BASE_DOMAIN>
#   dot-ai UI  : dot-ai-ui-<CLIENT_ID>.<BASE_DOMAIN>
BASE_DOMAIN=hub.example.com

# Ingress class name on the Hub cluster.
INGRESS_CLASS=nginx


# -----------------------------------------------------------------------------
# [REQUIRED] AI PROVIDER
# -----------------------------------------------------------------------------
# Supported values: openai | anthropic
AI_PROVIDER=openai

# API key for the chosen provider.
AI_API_KEY=sk-your-key-here


# -----------------------------------------------------------------------------
# [OPTIONAL] ADVANCED SETTINGS
# -----------------------------------------------------------------------------
# Helm release install timeout (seconds). Increase for slow clusters.
HELM_TIMEOUT=600

# Path to the dot-ai-stack Helm chart (relative to the repo root).
HELM_CHART_PATH=./dot-ai-stack

# Set to "true" to enable local HuggingFace embeddings on the Hub pod.
# Requires more memory but removes the need for an external embeddings API.
LOCAL_EMBEDDINGS=true

# Namespace on the CLIENT cluster where dot-ai resources will be bootstrapped.
# Usually "dot-ai" — only change if that namespace is already taken.
CLIENT_DOT_AI_NAMESPACE=dot-ai
